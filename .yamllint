---
extends: default

rules:
    indentation:
        spaces: 4
        indent-sequences: true
    line-length:
        max: 250
    truthy:
        check-keys: false
    document-start: disable
    comments:
        min-spaces-from-content: 1
    braces:
        min-spaces-inside: 0
        max-spaces-inside: 0
    brackets:
        min-spaces-inside: 0
        max-spaces-inside: 0
